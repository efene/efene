{erl_opts, [no_debug_info]}.
%% aleppo and ast_walk are vendored under src/vendor/ (see src/vendor/README.md)
{deps, []}.

{escript_incl_apps,
 [efene]}.
{escript_main_app, efene}.
{escript_name, efene}.
{escript_emu_args, "%%! +sbtu +A0\n"}.

%% Profiles
{profiles, [{test,
             [{erl_opts, [debug_info]}
            ]}]}.
